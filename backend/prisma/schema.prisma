// Phase 2 - Structuration des données (cf. Roadmap Phase 2 / CDC 2.2)
// Provider PostgreSQL : requis par le CDC pour l'intégrité des transactions
// financières (contraintes relationnelles fortes). Pour le dev/test local
// sans instance Postgres sous la main, voir backend/README.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// Utilisateurs (Back-Office) - séparation des rôles (CDC section 5)
// --------------------------------------------------------------------------
enum RoleUtilisateur {
  ADMIN
  ACCUEIL
  BAR
}

model Utilisateur {
  id             String          @id @default(cuid())
  email          String          @unique
  motDePasseHash String
  role           RoleUtilisateur
  actif          Boolean         @default(true)
  creeLe         DateTime        @default(now())
  majLe          DateTime        @updatedAt

  @@map("utilisateurs")
}

// --------------------------------------------------------------------------
// Catalogue Bar
// --------------------------------------------------------------------------
model Categorie {
  id       String    @id @default(cuid())
  nom      String    @unique
  ordre    Int       @default(0)
  produits Produit[]

  @@map("categories")
}

model Produit {
  id             String   @id @default(cuid())
  nom            String
  prixCentimes   Int
  categorieId    String
  categorie      Categorie @relation(fields: [categorieId], references: [id])
  actif          Boolean  @default(true)
  // Article créé "en dur" en attendant le lien avec l'API Trivec (pas
  // d'accès API à ce jour, cf. Roadmap Phase 2). Une fois l'intégration
  // branchée, ces articles seront rapprochés/complétés via codeTrivec plutôt
  // que recréés - la BDD se "remplira" en alignant sur le catalogue réel.
  estArticleTest Boolean  @default(false)
  codeTrivec     String?  @unique // renseigné uniquement une fois rapproché avec le vrai article Trivec
  creeLe         DateTime @default(now())
  majLe          DateTime @updatedAt

  lignesCommande CommandeLigne[]

  @@map("produits")
}

// --------------------------------------------------------------------------
// Commandes (multi-modules, cf. CDC 3 - "Prise de Commande Multi-Modules")
// --------------------------------------------------------------------------
enum StatutCommande {
  EN_COURS      // en construction côté borne, pas encore validée
  ENVOYEE_BAR   // (Bar) envoyée à Trivec (impression ticket), en attente de paiement si non payé au comptant borne
  PAYEE         // paiement confirmé (transactionTpeId obligatoire, cf. contrainte ci-dessous)
  ECHOUEE       // échec technique (Trivec injoignable, bot Conqueror en échec...)
  ANNULEE       // annulée (client parti sans payer, timeout, action staff)
}

enum ModuleCommande {
  BOWLING
  BAR
  KARAOKE
  QUIZ
}

// Compteur atomique par module, pour générer les identifiants humains
// (BO001, BA001, KA001...) - cf. Commande.numero. Une seule ligne par
// module, incrémentée via une requête SQL atomique (UPSERT), jamais lue puis
// réécrite en deux temps côté application (éviterait une course entre deux
// commandes créées au même instant sur deux bornes différentes).
model CompteurModule {
  module        ModuleCommande @id
  dernierNumero Int            @default(0)

  @@map("compteurs_module")
}

model Commande {
  id     String  @id @default(cuid())
  // Identifiant humain par module (BO001, BA001, KA001...), cf. CompteurModule.
  // Nullable : les quelques commandes de test créées avant l'introduction de
  // ce champ n'en ont pas (pas de backfill, données de test sans conséquence).
  numero String? @unique
  module ModuleCommande @default(BAR) // défaut BAR : toutes les commandes créées avant ce champ étaient des commandes Bar

  statut        StatutCommande @default(EN_COURS)
  totalCentimes Int            @default(0) // 0 pour Bowling tant que le paiement est simulé (Phase 3 pas encore faite)
  borneId       String?
  // Jamais de données carte brutes ici (CDC 2.3/5) : uniquement le statut/ID
  // renvoyé par le TPE une fois la transaction traitée nativement par lui.
  transactionTpeId String?
  moyenPaiement     String?  // "carte" | "especes" | "ce" | "simule" (Bowling, en attendant la Phase 3)... libre pour l'instant
  ticketTrivecId    String?  // (Bar) identifiant renvoyé par l'adaptateur Trivec (mock ou réel)
  erreur            String?  // dernier message d'erreur technique (Trivec injoignable, etc.)

  // Conditions générales de vente (encart affiché avant paiement, cf. Phase 4 app)
  cgvAccepteesLe DateTime?
  // QR/Pass CE saisi par le client - encart présent dès maintenant mais PAS
  // ENCORE validé (pas de vérification d'unicité/anti-fraude) : cf. Roadmap
  // Phase 4 (Pass CE - contrainte d'unicité en base contre le scan simultané).
  codeAvantageSaisi String?

  // Résultat du bot Conqueror (Bowling) - cf. src/botRelay.js
  botSucces Boolean?
  botErreur String?
  botPiste  Int?

  creeLe DateTime @default(now())
  majLe  DateTime @updatedAt

  lignes  CommandeLigne[]          // utilisé uniquement pour module=BAR
  joueurs CommandeJoueurBowling[]  // utilisé uniquement pour module=BOWLING

  @@map("commandes")
}

model CommandeLigne {
  id                   String   @id @default(cuid())
  commandeId           String
  commande             Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId            String
  produit              Produit  @relation(fields: [produitId], references: [id])
  quantite             Int
  // Prix figé au moment de la commande (indépendant d'un changement de prix
  // ultérieur du produit) - cf. CDC intégrité des transactions financières.
  prixUnitaireCentimes Int
  creeLe               DateTime @default(now())

  @@map("commande_lignes")
}

// --------------------------------------------------------------------------
// Commandes Bowling
// --------------------------------------------------------------------------
model CommandeJoueurBowling {
  id         String   @id @default(cuid())
  commandeId String
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  prenom     String
  bumpers    Boolean  @default(false)
  // Nombre de parties pour CE joueur - actuellement identique pour tous les
  // joueurs d'une même commande (l'app ne demande qu'un nombre de parties
  // global, cf. Roadmap Phase 4), gardé par joueur pour rester compatible
  // avec le bot (qui, lui, sait déjà gérer un nombre différent par joueur -
  // cf. bot/conqueror_bot.py - si on affine l'app plus tard).
  parties    Int      @default(1)
  creeLe     DateTime @default(now())

  @@map("commande_joueurs_bowling")
}
