# Copier en .env et remplir. Ne jamais committer le .env réel.

# Postgres - cf. backend/README.md pour les options d'hébergement (Hostinger
# mutualisé ne fait PAS tourner Postgres nativement : il faut soit un VPS
# Hostinger + Docker, soit un Postgres managé externe type Neon/Supabase).
# connect_timeout=10 : sans ça, si le réseau vers la BDD est bloqué/filtré
# (ex: hébergeur mutualisé qui restreint les connexions TCP sortantes sur le
# port 5432), la requête reste bloquée indéfiniment au lieu d'échouer
# proprement en 10s - cf. incident du 2026-07-19 (chargement infini sur
# Hostinger). Toujours garder ce paramètre en prod.
DATABASE_URL="postgresql://user:password@host:5432/bornes_bowling?sslmode=require&connect_timeout=10"

PORT=3000

# Trivec : "mock" (défaut, sans accès API) | "reel" (une fois l'API dispo)
TRIVEC_MODE=mock
# Pour tester le cas d'échec d'impression (Roadmap Phase 2 - qualité) :
# TRIVEC_MOCK_ECHEC=true
